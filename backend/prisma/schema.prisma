generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum Role {
  user
  staff
  admin
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  BACKLOG
}

enum LogAction {
  WITHDRAW
  ADD
  TRANSFER_OUT
  TRANSFER_IN
}

enum AllocationStrategy {
  FIFO
  LIFO
}

//
// USER
//

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String?   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())

  logs      Log[]
  orders    Order[]
  transfers Transfer[]
  auditLogs AuditLog[]
}

//
// ITEM
//

model Item {
  id        Int      @id @default(autoincrement())
  sku       String   @unique
  name      String
  category  String?
  minStock  Int      @default(10) // 👈 NEW (low stock detection)
  createdAt DateTime @default(now())

  locations  ItemLocation[]
  logs       Log[]
  orderLines OrderLine[]
  transfers  Transfer[]
}

//
// LOCATION
//

model Location {
  id        Int      @id @default(autoincrement())
  name      String
  zone      String?
  rack      String?
  bin       String?
  capacity  Int?     // used for "almost full"
  createdAt DateTime @default(now())

  items         ItemLocation[]
  logs          Log[]
  transfersFrom Transfer[] @relation("FromLocation")
  transfersTo   Transfer[] @relation("ToLocation")
}

//
// STOCK PER LOCATION
//

model ItemLocation {
  id         Int @id @default(autoincrement())
  itemId     Int
  locationId Int
  quantity   Int @default(0)

  item     Item     @relation(fields: [itemId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([itemId, locationId])
}

//
// TRANSFER
//

model Transfer {
  id             Int      @id @default(autoincrement())
  itemId         Int
  fromLocationId Int
  toLocationId   Int
  userId         Int
  quantity       Int
  createdAt      DateTime @default(now())

  item         Item     @relation(fields: [itemId], references: [id])
  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

//
// LOGS (for audit & reports)
//

model Log {
  id         Int       @id @default(autoincrement())
  userId     Int
  itemId     Int
  locationId Int
  quantity   Int
  action     LogAction
  reason     String?
  createdAt  DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id])
  item     Item     @relation(fields: [itemId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
}

//
// ORDERS
//

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  lines OrderLine[]
}

//
// ORDER LINE (important for backlog handling)
//

model OrderLine {
  id        Int @id @default(autoincrement())
  orderId   Int
  itemId    Int
  quantity  Int
  fulfilled Int @default(0) // 👈 NEW (track fulfilled qty)

  order Order @relation(fields: [orderId], references: [id])
  item  Item  @relation(fields: [itemId], references: [id])
}

model SystemSetting {
  id                  Int                @id @default(1)
  defaultReorderPoint Int                @default(10)
  lowStockBuffer      Int                @default(0)
  allocationStrategy  AllocationStrategy @default(FIFO)
  updatedAt           DateTime           @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
